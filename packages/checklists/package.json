{
  "name": "@vardi/checklists",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint --config ../../eslint.config.mjs src",
    "typecheck": "tsc --noEmit",
    "validate:seeds": "node ./scripts/validate-seeds.mjs",
