{
  "name": "vardi",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "pnpm --filter @vardi/web dev",
    "build": "pnpm --filter @vardi/web build",
    "lint": "pnpm lint:boundaries && pnpm -r lint",
    "lint:boundaries": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
